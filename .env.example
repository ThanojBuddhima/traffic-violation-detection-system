# Database
DATABASE_URL=sqlite:///./database/violations.db

# Storage (V1: local only)
STORAGE_BACKEND=local
STORAGE_LOCAL_UPLOADS_DIR=uploads
STORAGE_LOCAL_VIOLATIONS_DIR=violations

# V2 S3 (unused in V1)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_REGION=us-east-1

# Job queue (V2 only — leave CELERY_BROKER_URL unset for local V1)
USE_CELERY=false
# CELERY_BROKER_URL=redis://localhost:6379/0

# Inference
USE_MOCK_MODELS=true
HELMET_MODEL_PATH=models/helmet_best.pt
PLATE_MODEL_PATH=models/plate_best.pt
MIN_TRACK_FRAMES=5
NO_HELMET_RATIO=0.5
DEDUP_WINDOW_MINUTES=5
DELETE_RAW_VIDEO_AFTER_PROCESS=false

# API
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
